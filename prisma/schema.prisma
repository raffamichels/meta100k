generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  password   String
  goal       Float    @default(100000)
  baseAmount Float    @default(0)
  months     Month[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Month {
  id            String    @id @default(cuid())
  key           String
  salary        Float     @default(0)
  savings       Float     @default(0) // soma calculada dos registros Saving
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses      Expense[]
  extras        Extra[]
  savingEntries Saving[]  // registros individuais de economia

  @@unique([userId, key])
}

model Expense {
  id       String @id @default(cuid())
  desc     String
  value    Float
  category String
  date     String
  monthId  String
  month    Month  @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model Extra {
  id      String @id @default(cuid())
  desc    String
  value   Float
  date    String
  monthId String
  month   Month  @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model Saving {
  id      String @id @default(cuid())
  desc    String
  value   Float
  date    String
  monthId String
  month   Month  @relation(fields: [monthId], references: [id], onDelete: Cascade)
}
