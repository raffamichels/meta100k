generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  name           String?
  password       String
  goal           Float              @default(100000)
  baseAmount     Float              @default(0)
  months         Month[]
  // Gamification
  xp             Int                @default(0)
  level          Int                @default(1)
  maxStreak      Int                @default(0)
  streakShields  Int                @default(0)
  achievements   UserAchievement[]
  challenges     Challenge[]
  // Cofre do Diabo
  temptations    Temptation[]
  // Social
  createdSocialChallenges  SocialChallenge[]              @relation("SocialChallengeCreator")
  socialParticipations     SocialChallengeParticipant[]   @relation("SocialChallengeParticipant")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Month {
  id            String    @id @default(cuid())
  key           String
  salary        Float     @default(0)
  savings       Float     @default(0) // soma calculada dos registros Saving
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses      Expense[]
  extras        Extra[]
  savingEntries Saving[]  // registros individuais de economia

  @@unique([userId, key])
}

model Expense {
  id       String @id @default(cuid())
  desc     String
  value    Float
  category String
  date     String
  monthId  String
  month    Month  @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model Extra {
  id      String @id @default(cuid())
  desc    String
  value   Float
  date    String
  monthId String
  month   Month  @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model Saving {
  id      String @id @default(cuid())
  desc    String
  value   Float
  date    String
  monthId String
  month   Month  @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model UserAchievement {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key        String   // identificador da conquista (ex: "streak_7", "save_10k")
  unlockedAt DateTime @default(now())

  @@unique([userId, key])
}

model Challenge {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    // "weekly" | "monthly"
  key         String    // tipo do desafio (ex: "save_target", "daily_streak")
  target      Float
  current     Float     @default(0)
  xpReward    Int
  startDate   String
  endDate     String
  completed   Boolean   @default(false)
  completedAt DateTime?
}

model Temptation {
  id        String   @id @default(cuid())
  desc      String                        // "Tênis Nike Air Max"
  value     Float                         // 350.00
  category  String                        // "Vestuário"
  place     String?                       // "Shopping Iguatemi" (opcional)
  date      String                        // "2026-03-03"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model SocialChallenge {
  id           String                     @id @default(cuid())
  creatorId    String
  creator      User                       @relation("SocialChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  mode         String                     // "hard" | "savings"
  days         Int?                       // 30, 60, 90 — apenas modo "savings"
  startDate    String                     // YYYY-MM-DD
  endDate      String?                    // YYYY-MM-DD — apenas modo "savings"
  status       String                     @default("pending") // "pending" | "active" | "finished"
  participants SocialChallengeParticipant[]
  createdAt    DateTime                   @default(now())
}

model SocialChallengeParticipant {
  id          String          @id @default(cuid())
  challengeId String
  challenge   SocialChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation("SocialChallengeParticipant", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime        @default(now())

  @@unique([challengeId, userId])
}
